package de.tha.prog2;

public class Vector extends AbstractContainer {
	
	int size = 0;
	Object[] data = new Object[size];

	@Override
	public boolean add(Object o) {
		
		Object[] newArray = new Object[++size];
		
		for (int i = 0; i < data.length; i++) {
			newArray[i] = data[i];
		}
		newArray[size-1] = o; 
		data = newArray;
		return true;
		
	}

	@Override
	public Object get(int i) {
		if (data[i] == null) {
			return null;
		}
		return data[i];
	}

	@Override
	public int size() {
		return this.size;
	}

	@Override
	public boolean remove(Object o) {
		int index = -1;
		int cnt = 0;
		
		for (int i = 0; i < size; i++) {
			if (data[i].equals(o)) {
				index = i;
				break;
			}
		}
		
		if (index == -1) {
			return false;
		}
		
		Object[] newArray = new Object[size - 1];
		
		for (int i = 0; i < size; i++) {
			if (i != index) {
				newArray[cnt++] = data[i];
			}
		}
		data = newArray;
		size--;
		return true;
	}

}
